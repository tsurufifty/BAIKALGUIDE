# ---- Public site ----
NEXT_PUBLIC_SITE_URL=https://baikal-guide.ru

# ---- Strapi API ----
# Origin only — the client appends /api itself. Local dev: http://localhost:1337
NEXT_PUBLIC_STRAPI_URL=https://baikal-guide.ru
# Used only on the server (Docker). Lets SSR reach Strapi by service name.
STRAPI_INTERNAL_URL=http://backend:1337
# Hostname only (used by next/image remotePatterns)
NEXT_PUBLIC_STRAPI_IMAGE_HOST=baikal-guide.ru
# Server-side read token (optional for public content)
STRAPI_API_TOKEN=

# ---- Yandex Maps JS API 3.0 (lazy-loaded on the map page) ----
# Free key from the Yandex developer cabinet (no card needed for the free tier).
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
