{
  "kind": "collectionType",
  "collectionName": "locations",
  "info": {
    "singularName": "location",
    "pluralName": "locations",
    "displayName": "Location",
    "description": "Map points of interest"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "description": {
      "type": "blocks",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "category": {
      "type": "enumeration",
      "enum": ["nature", "culture", "gastronomy", "viewpoint", "lodging", "transport", "other"],
      "default": "nature",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "coordinates": {
      "type": "component",
      "repeatable": false,
      "component": "map.geo-point",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images", "videos"],
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "events": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::event.event",
      "mappedBy": "location",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "routes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::route.route",
      "mappedBy": "locations",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "pluginOptions": { "i18n": { "localized": true } }
    }
  }
}
