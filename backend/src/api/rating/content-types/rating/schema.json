{
  "kind": "collectionType",
  "collectionName": "ratings",
  "info": {
    "singularName": "rating",
    "pluralName": "ratings",
    "displayName": "Rating",
    "description": "User ratings for routes (1–5, one per user per route, not localized)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": false
    }
  },
  "attributes": {
    "value": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 5
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "route": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::route.route",
      "inversedBy": "ratings"
    }
  }
}
