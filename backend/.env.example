# ---- Strapi server ----
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=https://baikal-guide.ru/api

# Generate each value with: openssl rand -base64 32
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=changeme
ADMIN_JWT_SECRET=changeme
TRANSFER_TOKEN_SALT=changeme
JWT_SECRET=changeme
JWT_EXPIRES_IN=7d

# ---- Database (PostgreSQL, managed by Strapi) ----
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=baikal
DATABASE_USERNAME=baikal
DATABASE_PASSWORD=changeme
DATABASE_SSL=false
DATABASE_SCHEMA=public

# ---- CORS (frontend origins, comma-separated) ----
CORS_ORIGINS=http://localhost:3000,https://baikal-guide.ru

# ---- Uploads ----
UPLOAD_SIZE_LIMIT=52428800

# Seed demo content on first boot (true once, then false)
SEED_DATA=false
