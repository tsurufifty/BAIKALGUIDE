# ============================================================
#  Baikal Guide — root environment (used by docker compose)
#  Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ---- PostgreSQL (managed by Strapi) ----
DATABASE_NAME=baikal
DATABASE_USERNAME=baikal
DATABASE_PASSWORD=change_me_strong

# ---- Strapi secrets (generate each: openssl rand -base64 32) ----
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=change_me
ADMIN_JWT_SECRET=change_me
TRANSFER_TOKEN_SALT=change_me
JWT_SECRET=change_me

# Public URL Strapi advertises (behind nginx, /api is proxied to backend)
STRAPI_PUBLIC_URL=https://baikal-guide.ru/api
CORS_ORIGINS=https://baikal-guide.ru,https://www.baikal-guide.ru

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_SITE_URL=https://baikal-guide.ru
# Origin only — the frontend appends /api itself (nginx proxies /api -> backend).
# Local dev without Docker: http://localhost:1337
NEXT_PUBLIC_STRAPI_URL=https://baikal-guide.ru
# Internal URL for server-side fetches inside Docker (set automatically in compose).
STRAPI_INTERNAL_URL=http://backend:1337
NEXT_PUBLIC_STRAPI_IMAGE_HOST=baikal-guide.ru
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your_yandex_maps_js_api_key
# Optional server-side read token for protected content
STRAPI_API_TOKEN=

# ---- First-run demo content (set true once, then back to false) ----
SEED_DATA=false
